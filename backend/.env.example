OPENAI_API_KEY=your_openai_api_key_here

# Apify API token (used by /webhook/jobs to fetch dataset items)
APIFY_API_KEY=your_apify_api_key_here

PORT=3001

# Public base URL of the backend (used for generating download links)
# Example (your deployment):
PUBLIC_BASE_URL=https://bidding-system-sl40.onrender.com

# Render persistent disk root (Render mounts your disk at /var/data)
DATA_DIR=/var/data

# Where to save uploaded profile templates (PDF/DOC/DOCX)
TEMPLATE_UPLOAD_DIR=/var/data/template

# Where to save uploaded bid screenshots (images)
SCREENSHOT_UPLOAD_DIR=/var/data/screenshot

# Optional: where to save temporary uploads for /api/generate-resume (deleted after response)
TEMP_UPLOAD_DIR=/var/data/tmp

# Optional: where to save generated resume outputs (downloaded later)
OUTPUTS_DIR=/var/data/outputs
